                    <script>
                        // API endpoints for images(banners)
                        const API_BASE = "/api";
                        const api = {
                            list: `${API_BASE}/Banners`,
                            create: `${API_BASE}/bannerCreate`,
                            get: id => `${API_BASE}/getBanner/${id}`,
                            update: id => `${API_BASE}/editBanner/${id}`,
                            delete: id => `${API_BASE}/deleteBanner/${id}`,
                            active: `${API_BASE}/bannerActive`
                        };

                        let bannerCurrentPage = 1;
                        let bannerLimit = 10;
                        let bannerSearchQuery = '';
                        let totalCount = 0;



                        function renderBannerRows(banners) {
                            const $list = $('#banners-list');
                            $list.html('');
                            if (!banners.length) {
                                $list.append('<tr><td colspan="5" class="text-center">No banners found</td></tr>');
                                return;
                            }

                            banners.forEach(function (banner) {
                                const date = banner.createdAt ? new Date(banner.createdAt).toLocaleDateString() : '';

                                const imageCell = banner.imageUrl
                                    ? `<img class="banner-thumb" src="${banner.imageUrl}" alt="${banner.title || ''}">`
                                    : `<div class="no-image-placeholder"><i class="icon-image"></i></div>`;

                                const statusBadge = banner.isActive
                                    ? `<span class="status-badge active">Active</span>`
                                    : `<span class="status-badge inactive">Inactive</span>`;

                                const toggleClass = banner.isActive ? 'toggle' : 'toggle inactive';
                                const toggleIcon = banner.isActive ? 'icon-toggle-right' : 'icon-toggle-left';
                                const toggleTitle = banner.isActive ? 'Deactivate' : 'Activate';

                                $list.append(`
            <tr data-id="${banner._id}">
                <td>${imageCell}</td>
                <td><div class="banner-name">${banner.title || ''}</div></td>
                <td>${statusBadge}</td>
                <td>${date}</td>
                <td>
                    <div class="banner-actions">
                        <button class="item edit" title="Edit" onclick="showEditBannerModal('${banner._id}')">
                            <i class="icon-edit-3"></i>
                        </button>
                        <button class="item ${toggleClass}" title="${toggleTitle}" onclick="toggleBannerStatus('${banner._id}')">
                            <i class="${toggleIcon}"></i>
                        </button>
                        <button class="item trash" title="Delete" onclick="showDeleteConfirmModal('${banner._id}')">
                            <i class="icon-trash-2"></i>
                        </button>
                    </div>
                </td>
            </tr>
        `);
                            });
                        }

                        function toggleBannerStatus(id) {
                            $.ajax({
                                url: api.active,
                                method: 'POST',
                                contentType: 'application/json',
                                data: JSON.stringify({ id }),
                                success: function () {
                                    loadBanners();
                                },
                                error: function (res) {
                                    alert((res.responseJSON && res.responseJSON.message) || 'Failed to toggle status');
                                }
                            });
                        }


                        function loadBanners() {
                            let url = `${api.list}?limit=${bannerLimit}&page=${bannerCurrentPage}`;
                            if (bannerSearchQuery) {
                                url += `&search=${encodeURIComponent(bannerSearchQuery)}`;
                            }
                            $.get(url)
                                .done(data => {
                                    // Accept .data or .banners
                                    let banners = [];
                                    if (data.data && Array.isArray(data.data)) {
                                        banners = data.data;
                                    } else if (Array.isArray(data.banners)) {
                                        banners = data.banners;
                                    }
                                    renderBannerRows(banners);
                                    $('#banner-showing-entries').text(
                                        `Showing ${banners.length} entries`
                                    );
                                    // TODO: Update pagination if needed
                                })
                                .fail(err => {
                                    $('#banners-list').html('<tr><td colspan="6" class="text-center text-danger">Failed to load banners</td></tr>');
                                });
                        }

                        // MODAL SHOW/HIDE FUNCTIONS
                        function showAddBannerModal() {
                            $('#add-banner-form')[0].reset();
                            $('#add-image-preview').html('');
                            $('#add-banner-modal').show();
                        }
                        function showEditBannerModal(id) {
                            $.get(api.get(id))
                                .done(res => {

                                    const banner = res.data || res;
                                    $('#edit-banner-id').val(banner._id);
                                    $('#edit-banner-title').val(banner.title);
                                    $('#edit-banner-subtitle').val(banner.subtitle || '');
                                    $('#edit-banner-description').val(banner.description || '');

                                    if (banner.imageUrl) {
                                        $('#edit-current-image').attr('src', banner.imageUrl);
                                        $('#edit-current-image-wrap').show();
                                    } else {
                                        $('#edit-current-image-wrap').hide();
                                    }

                                    $('#edit-banner-image').val('');
                                    $('#edit-image-preview').html('');

                                    $('#edit-banner-modal').show();
                                });
                        }
                        function showDeleteConfirmModal(id) {
                            $('#confirm-delete-btn').off('click').on('click', function () {
                                deleteBanner(id);
                            });
                            $('#delete-confirm-modal').show();
                        }
                        function closeModal(modalId) {
                            $('#' + modalId).hide();
                        }

                        // HANDLERS
                        $(document).on('submit', '#add-banner-form', function (e) {


                            e.preventDefault();
                            const formData = new FormData();
                            formData.append('title', $('#add-banner-title').val().trim());
                            formData.append('subtitle', $('#add-banner-subtitle').val().trim());
                            formData.append('description', $('#add-banner-description').val().trim());
                            const imageFile = $('#add-banner-image')[0].files[0];
                            if (!imageFile) {
                                alert('Please select an image for the banner');
                                return;
                            }

                            formData.append('image', imageFile);

                            $.ajax({
                                url: api.create,
                                method: 'POST',
                                data: formData,
                                processData: false,
                                contentType: false,
                                success: function () {
                                    closeModal('add-banner-modal');
                                    loadBanners();
                                },
                                error: function (res) {
                                    alert((res.responseJSON && res.responseJSON.message) || 'Failed to create banner');
                                }
                            });
                        });

                        //edit form submit

                        $(document).on('submit', '#edit-banner-form', function (e) {
                            e.preventDefault();
                            const id = $('#edit-banner-id').val();
                            const formData = new FormData();
                            formData.append('title', $('#edit-banner-title').val().trim());
                            formData.append('subtitle', $('#edit-banner-subtitle').val().trim());
                            formData.append('description', $('#edit-banner-description').val().trim());
                            const imageFile = $('#edit-banner-image')[0].files[0];
                            if (imageFile) {
                                formData.append('image', imageFile);
                            }

                            $.ajax({
                                url: api.update(id),
                                method: 'PUT',
                                data: formData,
                                processData: false,
                                contentType: false,
                                success: function () {
                                    closeModal('edit-banner-modal');
                                    loadBanners();
                                },
                                error: function (res) {
                                    alert((res.responseJSON && res.responseJSON.message) || 'Failed to update banner');
                                }
                            });
                        });

                        function deleteBanner(id) {
                            $.ajax({
                                url: api.delete(id),
                                method: 'DELETE',
                                success: function () {
                                    closeModal('delete-confirm-modal');
                                    loadBanners();
                                },
                                error: function (res) {
                                    alert((res.responseJSON && res.responseJSON.message) || 'Failed to delete');
                                }
                            });
                        }

                        // Search and limit
                        $('#banner-search-btn').click(function () {
                            bannerSearchQuery = $('#banner-search-input').val().trim();
                            loadBanners();
                        });
                        $('#banner-limit-select').change(function () {
                            bannerLimit = $(this).val();
                            loadBanners();
                        });

                        // Initial load
                        $(document).ready(function () {
                            loadBanners();
                        });

                    </script>
                    <!-- /main-content -->
                </div>
                <!-- /section-content-right -->
            </div>
            <!-- /layout-wrap -->
        </div>
        <!-- /#page -->
    </div>
    <!-- /#wrapper -->

    <!-- Javascript -->
    <script src="/admin-js/jquery.min.js"></script>
    <script src="/admin-js/bootstrap.min.js"></script>
    <script src="/admin-js/bootstrap-select.min.js"></script>

    <script>
        function bindImagePreview(inputSelector, previewSelector) {

            $(document).on('change', inputSelector, function () {

                const $preview = $(previewSelector);

                $preview.html('');

                const files = this.files;

                if (!files || !files.length) return;

                Array.from(files).forEach(function (file) {

                    if (!file.type.startsWith('image/')) return;

                    const reader = new FileReader();

                    reader.onload = function (e) {

                        $preview.append(`<div style="width:120px;height:80px;border-radius:8px;overflow:hidden;border:2px solid #e9ecef;"><img src="${e.target.result}" style="width:100%;height:100%;object-fit:cover;"></div>`);

                    };

                    reader.readAsDataURL(file);

                });

            });

        }

        bindImagePreview('#add-banner-image', '#add-image-preview');

        bindImagePreview('#edit-banner-image', '#edit-image-preview');




        ['add-upload-area', 'edit-upload-area'].forEach(function (id) {

            const el = document.getElementById(id); if (!el) return;

            el.addEventListener('dragover', function (e) { e.preventDefault(); el.classList.add('dragover'); });

            el.addEventListener('dragleave', function () { el.classList.remove('dragover'); });

            el.addEventListener('drop', function (e) { e.preventDefault(); el.classList.remove('dragover'); });

        });
    </script>
    <script>
        // Prevent zoom.js errors by patching addEventListener before zoom.js loads
        (function () {
            var originalAddEventListener = Element.prototype.addEventListener;
            Element.prototype.addEventListener = function (type, listener, options) {
                if (this === null || this === undefined) {
                    console.warn('Attempted to addEventListener on null/undefined element');
                    return;
                }
                try {
                    return originalAddEventListener.call(this, type, listener, options);
                } catch (e) {
                    console.warn('addEventListener error prevented:', e);
                }
            };
        })();
