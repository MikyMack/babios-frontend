<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en-US" lang="en-US">

<head>
    <!-- Basic Page Needs -->
    <meta charset="utf-8">
    <title>Babios- Product Management</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">

    <!-- Theme Style -->
    <link rel="stylesheet" type="text/css" href="/admin-css/animate.min.css">
    <link rel="stylesheet" type="text/css" href="/admin-css/animation.css">
    <link rel="stylesheet" type="text/css" href="/admin-css/bootstrap.css">
    <link rel="stylesheet" type="text/css" href="/admin-css/bootstrap-select.min.css">
    <link rel="stylesheet" type="text/css" href="/admin-css/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">

    <!-- Font -->
    <link rel="stylesheet" href="/admin-font/fonts.css">

    <!-- Icon -->
    <link rel="stylesheet" href="/admin-icon/style.css">

    <!-- Favicon and Touch Icons  -->
    <link rel="shortcut icon" href="/images/babios/logo.png">
    <link rel="apple-touch-icon-precomposed" href="/images/babios/logo.png">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

</head>

<body class="body">

    <!-- #wrapper -->
    <div id="wrapper">
        <!-- #page -->
        <div id="page" class="">
            <!-- layout-wrap -->
            <div class="layout-wrap loader-off">
                <!-- section-menu-left -->
                <div class="section-menu-left">
                    <div class="box-logo">
                        <a href="/admin/dashboard" id="site-logo-inner">
                            <img style="width:60px;" id="logo_header" alt="logo" src="/images/babios/logo.png"
                                data-light="/images/babios/logo.png" data-dark="/images/babios/logo.png">
                        </a>
                        <div class="button-show-hide">
                            <i class="icon-chevron-left"></i>
                        </div>
                    </div>
                    <div class="section-menu-left-wrap">
                        <div class="center">
                            <div class="center-item">
                                <ul>
                                    <li class="menu-item active">
                                        <a href="/admin/dashboard">
                                            <div class="icon">
                                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                                                    xmlns="http://www.w3.org/2000/svg">
                                                    <path fill-rule="evenodd" clip-rule="evenodd"
                                                        d="M12.2652 3.57566C12.1187 3.42921 11.8813 3.42921 11.7348 3.57566L5.25 10.0605V19.8748C5.25 20.0819 5.41789 20.2498 5.625 20.2498H9V16.1248C9 15.0893 9.83947 14.2498 10.875 14.2498H13.125C14.1605 14.2498 15 15.0893 15 16.1248V20.2498H18.375C18.5821 20.2498 18.75 20.0819 18.75 19.8748V10.0605L12.2652 3.57566ZM20.25 11.5605L21.2197 12.5302C21.5126 12.8231 21.9874 12.8231 22.2803 12.5302C22.5732 12.2373 22.5732 11.7624 22.2803 11.4695L13.3258 2.51499C12.5936 1.78276 11.4064 1.78276 10.6742 2.515L1.71967 11.4695C1.42678 11.7624 1.42678 12.2373 1.71967 12.5302C2.01256 12.8231 2.48744 12.8231 2.78033 12.5302L3.75 11.5605V19.8748C3.75 20.9104 4.58947 21.7498 5.625 21.7498H18.375C19.4105 21.7498 20.25 20.9104 20.25 19.8748V11.5605ZM13.5 20.2498H10.5V16.1248C10.5 15.9177 10.6679 15.7498 10.875 15.7498H13.125C13.3321 15.7498 13.5 15.9177 13.5 16.1248V20.2498Z"
                                                        fill="#111111" />
                                                </svg>
                                            </div>
                                            <div class="text">Admin Dashboard</div>
                                        </a>
                                    </li>


                                    <li class="menu-item">
                                        <a href="/admin/contact" class="menu-item-button">
                                            <div class="icon"><i class="icon-mail"></i></div>
                                            <div class="text">Contact Management</div>
                                        </a>
                                    </li>


                                    <li class="menu-item">
                                        <a href="/admin/banner" class="menu-item-button">
                                            <div class="icon"><i class="icon-image"></i></div>
                                            <div class="text">Banner Management</div>
                                        </a>
                                    </li>

                                    <li class="menu-item">
                                        <a href="/admin/testimonials" class="menu-item-button">
                                            <div class="icon"><i class="fa fa-star-o"></i></div>
                                            <div class="text">Testimonials Management</div>
                                        </a>
                                    </li>

                                    <li class="menu-item">
                                        <a href="/admin/blogs" class="menu-item-button">
                                            <div class="icon"><i class="icon-book-open"></i></div>
                                            <div class="text">Blogs Management</div>
                                        </a>
                                    </li>

                                    <li class="menu-item">
                                        <a href="/admin/logout">
                                            <div class="icon">
                                                <svg width="24" height="22" viewBox="0 0 20 20" fill="none"
                                                    xmlns="http://www.w3.org/2000/svg">
                                                    <path
                                                        d="M8.125 18.6875C8.125 18.903 8.0394 19.1097 7.88702 19.262C7.73465 19.4144 7.52799 19.5 7.3125 19.5H1.625C1.19402 19.5 0.780698 19.3288 0.475951 19.024C0.171205 18.7193 0 18.306 0 17.875V1.625C0 1.19402 0.171205 0.780698 0.475951 0.475951C0.780698 0.171205 1.19402 0 1.625 0H7.3125C7.52799 0 7.73465 0.0856026 7.88702 0.237976C8.0394 0.390349 8.125 0.597012 8.125 0.8125C8.125 1.02799 8.0394 1.23465 7.88702 1.38702C7.73465 1.5394 7.52799 1.625 7.3125 1.625H1.625V17.875H7.3125C7.52799 17.875 7.73465 17.9606 7.88702 18.113C8.0394 18.2653 8.125 18.472 8.125 18.6875ZM19.2623 9.17516L15.1998 5.11266C15.0474 4.9602 14.8406 4.87455 14.625 4.87455C14.4094 4.87455 14.2026 4.9602 14.0502 5.11266C13.8977 5.26511 13.812 5.47189 13.812 5.6875C13.812 5.90311 13.8977 6.10989 14.0502 6.26234L16.7263 8.9375H7.3125C7.09701 8.9375 6.89035 9.0231 6.73798 9.17548C6.5856 9.32785 6.5 9.53451 6.5 9.75C6.5 9.96549 6.5856 10.1722 6.73798 10.3245C6.89035 10.4769 7.09701 10.5625 7.3125 10.5625H16.7263L14.0502 13.2377C13.8977 13.3901 13.812 13.5969 13.812 13.8125C13.812 14.0281 13.8977 14.2349 14.0502 14.3873C14.2026 14.5398 14.4094 14.6255 14.625 14.6255C14.8406 14.6255 15.0474 14.5398 15.1998 14.3873L19.2623 10.3248C19.3379 10.2494 19.3978 10.1598 19.4387 10.0611C19.4796 9.9625 19.5006 9.85678 19.5006 9.75C19.5006 9.64322 19.4796 9.5375 19.4387 9.43886C19.3978 9.34023 19.3379 9.25062 19.2623 9.17516Z"
                                                        fill="#111111" />
                                                </svg>
                                            </div>
                                            <div class="text">Log out</div>
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- /section-menu-left -->
                <!-- section-content-right -->
                <div class="section-content-right">
                    <!-- header-dashboard -->
                    <div class="header-dashboard">
                        <div class="wrap">
                            <div class="header-left">
                                <a href="/admin/dashboard">
                                    <img style="width: 50px;" id="logo_header_mobile" alt=""
                                        src="/images/babios/logo.png" data-light="/images/babios/logo.png"
                                        data-dark="/images/babios/logo.png">
                                </a>
                                <div class="button-show-hide">
                                    <i class="icon-chevron-left"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- /header-dashboard -->

                    <!-- main-content -->
                    <div class="main-content">
                        <!-- main-content-wrap -->
                        <div class="main-content-inner">
                            <!-- main-content-wrap -->
                            <div class="main-content-wrap">
                                <div class="flex items-center flex-wrap justify-between gap20 mb-30">
                                    <h3>Contact Management</h3>
                                    <ul class="breadcrumbs flex items-center flex-wrap justify-start gap10">
                                        <li>
                                            <a href="/admin/dashboard">
                                                <div class="text-tiny">Dashboard</div>
                                            </a>
                                        </li>
                                        <li>
                                            <i class="icon-chevron-right"></i>
                                        </li>
                                        <li>
                                            <a href="#">
                                                <div class="text-tiny">Contacts</div>
                                            </a>
                                        </li>
                                        <li>
                                            <i class="icon-chevron-right"></i>
                                        </li>
                                        <li>
                                            <div class="text-tiny">Contact Management</div>
                                        </li>
                                    </ul>
                                </div>

                                <div class="row mb-30"
                                    style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 30px;">
                                    <div class="wg-box">
                                        <div class="flex items-center justify-between">
                                            <div>
                                                <div class="body-text mb-2">Total Contacts</div>
                                                <h4 id="stat-total-contacts">
                                                    <%= typeof totalCount !=='undefined' ? totalCount : 0 %>
                                                </h4>
                                            </div>
                                            <i class="icon-users" style="font-size: 48px; opacity: 0.2;"></i>
                                        </div>
                                    </div>
                                    <div class="wg-box">
                                        <div class="flex items-center justify-between">
                                            <div>
                                                <div class="body-text mb-2">Unread</div>
                                                <h4 id="stat-unread">
                                                    <%= typeof unreadCount !=='undefined' ? unreadCount : 0 %>
                                                </h4>
                                            </div>
                                            <i class="icon-mail"
                                                style="font-size: 48px; opacity: 0.2; color: #ffa500;"></i>
                                        </div>
                                    </div>
                                    <div class="wg-box">
                                        <div class="flex items-center justify-between">
                                            <div>
                                                <div class="body-text mb-2">Replied</div>
                                                <h4 id="stat-replied">
                                                    <%= typeof repliedCount !=='undefined' ? repliedCount : 0 %>
                                                </h4>
                                            </div>
                                            <i class="icon-check-circle"
                                                style="font-size: 48px; opacity: 0.2; color: #20c997;"></i>
                                        </div>
                                    </div>
                                </div>

                                <div class="wg-box">
                                    <div class="title-box">
                                        <i class="icon-mail"></i>
                                        <div class="body-text">Manage your contacts. View messages, reply, or remove
                                            contacts as required.</div>
                                    </div>

                                    <!-- ✅ ADD IT HERE -->
                                    <div
                                        style="display:flex; gap:10px; margin-bottom:20px; flex-wrap:wrap; align-items:center;">
                                        <input type="text" id="contact-search-input"
                                            placeholder="Search by name, email or phone..." class="tf-search-input"
                                            style="flex:1; min-width:200px; padding:8px 12px; border:1px solid #ddd; border-radius:6px;">
                                        <button id="contact-search-btn" class="btn btn-primary btn-sm">
                                            <i class="icon-search"></i> Search
                                        </button>
                                        <select id="contact-status-filter" class="tf-search-input"
                                            style="padding:8px 12px; border:1px solid #ddd; border-radius:6px;">
                                            <option value="">All Status</option>
                                            <option value="unread">Unread</option>
                                            <option value="read">Replied</option>
                                        </select>
                                    </div>



                                    <!-- Contacts List Container -->
                                    <div class="contacts-container" id="contacts-list" style="min-height: 200px;"></div>

                                    <!-- Pagination -->
                                    <div class="flex items-center justify-between flex-wrap gap10 mt-4">
                                        <div class="text-tiny" id="showing-entries">Showing 0 entries</div>
                                        <ul class="wg-pagination" id="contact-pagination"></ul>
                                    </div>
                                </div>

                                <!-- VIEW CONTACT MODAL -->
                                <div id="view-contact-modal" class="modal" style="display: none;">
                                    <div class="modal-content modern-modal modal-lg">
                                        <div class="modal-header">
                                            <div class="modal-title">
                                                <i class="icon-eye"></i>
                                                <h3>Contact Message</h3>
                                            </div>
                                            <button type="button" class="close-btn"
                                                onclick="closeModal('view-contact-modal')">
                                                <i class="icon-x"></i>
                                            </button>
                                        </div>
                                        <div class="modal-body" id="view-contact-content"
                                            style="max-height: 70vh; overflow-y: auto;">
                                            <!-- Contact details will be loaded here -->
                                        </div>
                                    </div>
                                </div>

                                <!-- CONFIRM DELETE MODAL -->
                                <div class="modal" id="confirm-delete-modal" style="display: none;">
                                    <div class="modal-content modern-modal">
                                        <div class="modal-header">
                                            <h4><i class="icon-trash-2"></i> Confirm Delete</h4>
                                            <button type="button" class="close-btn"
                                                onclick="closeModal('confirm-delete-modal')"><i
                                                    class="icon-x"></i></button>
                                        </div>
                                        <div class="modal-body">
                                            <p>Are you sure you want to delete this contact message? This action cannot
                                                be undone.
                                            </p>
                                            <div class="form-actions"
                                                style="display: flex; gap: 10px; justify-content: flex-end;">
                                                <button type="button" class="btn btn-secondary"
                                                    onclick="closeModal('confirm-delete-modal')">Cancel</button>
                                                <button type="button" class="btn btn-danger" id="confirm-delete-btn"><i
                                                        class="icon-trash-2"></i> Delete</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>


                            </div>

                            <!-- Scripts -->
                            <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
                            <script
                                src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.1/moment.min.js"></script>
                            <script>
                                const CONTACT_LIST_API = '/api/contact/list';
                                const CONTACT_DETAIL_API = '/api/contact';
                                const CONTACT_MARK_REPLIED_API = '/api/mark-read-contact';
                                const CONTACT_DELETE_API = '/api/deleteContact';

                                let contactPage = 1;
                                let contactLimit = 10;
                                let contactSearchQuery = '';
                                let contactStatusFilter = '';
                                let contactTotalPages = 1;
                                let contactDeleteId = null;

                                $(document).ready(function () {
                                    loadContacts();

                                    $('#contact-search-btn').click(function () {
                                        contactSearchQuery = $('#contact-search-input').val().trim();
                                        contactPage = 1;
                                        loadContacts();
                                    });

                                    $('#contact-search-input').keypress(function (e) {
                                        if (e.which === 13) {
                                            contactSearchQuery = $(this).val().trim();
                                            contactPage = 1;
                                            loadContacts();
                                        }
                                    });

                                    $('#contact-status-filter').change(function () {
                                        contactStatusFilter = $(this).val();
                                        contactPage = 1;
                                        loadContacts();
                                    });

                                    $('#confirm-delete-btn').click(function () {
                                        if (contactDeleteId) deleteContact(contactDeleteId);
                                    });
                                });

                                // ── Load contacts from API ──────────────────────────────────────────────────
                                function loadContacts() {
                                    let url = `${CONTACT_LIST_API}?page=${contactPage}&limit=${contactLimit}`;
                                    if (contactSearchQuery) url += `&search=${encodeURIComponent(contactSearchQuery)}`;
                                    if (contactStatusFilter) url += `&status=${encodeURIComponent(contactStatusFilter)}`;

                                    $.ajax({
                                        url,
                                        method: 'GET',
                                        success: function (res) {
                                            const contacts = res.contacts || [];
                                            const total = res.total || 0;
                                            const totalPages = res.totalPages || 1;

                                            renderContacts(contacts);
                                            updateContactPagination(totalPages);
                                            $('#showing-entries').text(`Showing ${contacts.length} of ${total} entries`);
                                        },
                                        error: function () {
                                            $('#contacts-list').html(
                                                '<div style="text-align:center;padding:40px;color:#666;">Failed to load contacts</div>'
                                            );
                                        }
                                    });
                                }

                                // ── Render contact cards ────────────────────────────────────────────────────
                                function renderContacts(contacts) {
                                    const $container = $('#contacts-list').empty();

                                    if (!contacts.length) {
                                        $container.html('<div style="text-align:center;padding:40px;color:#666;">No contact messages found</div>');
                                        return;
                                    }

                                    contacts.forEach(c => {
                                        const date = moment(c.createdAt).format('MMM DD, YYYY h:mm A');
                                        const statusClass = c.isRead ? 'badge-success' : 'badge-warning';
                                        const statusText = c.isRead ? 'Replied' : 'Unread';


                                        $container.append(`
                <div class="event-card" data-id="${c._id}" style="box-shadow:none;">
                    <div class="event-info" style="flex:1;">
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
                            <h4 style="font-size:16px; margin:0;">${escapeHtml(c.fullName)}</h4>
                            <span class="event-badge ${statusClass}">${statusText}</span>
                        </div>
                        <div class="event-meta" style="margin-bottom:4px;">
                            <span><i class="icon-mail"></i>
                                <a href="mailto:${escapeHtml(c.email)}">${escapeHtml(c.email)}</a>
                            </span>
                            <span><i class="icon-phone"></i> ${escapeHtml(c.mobileNumber)}</span>
                        </div>
                       <div style="font-size:13px;color:#555;margin-top:4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:85vw;">
    <strong>Subject:</strong> ${escapeHtml((c.subject || '-').substring(0, 100))}${(c.subject || '').length > 100 ? '…' : ''}
</div>
                        <div style="font-size:12px;color:#999;margin-top:4px;">Received: ${date}</div>
                    </div>
                    <div class="event-actions">
                        <button class="btn btn-sm btn-info"   onclick="viewContact('${c._id}')"             title="View"><i class="icon-eye"></i></button>
                        <button class="btn btn-sm btn-danger" onclick="openDeleteContactModal('${c._id}')"  title="Delete"><i class="icon-trash-2"></i></button>
                    </div>
                </div>
            `);
                                    });
                                }

                                // ── View contact detail ─────────────────────────────────────────────────────
                                function viewContact(id) {
                                    $.ajax({
                                        url: `${CONTACT_DETAIL_API}/${id}`,
                                        method: 'GET',
                                        success: function (res) {
                                            showContactDetails(res.data || res);
                                            $('#view-contact-modal').css({ display: 'flex', alignItems: 'center', justifyContent: 'center' }).show();
                                        },
                                        error: function () { showNotification('Failed to load contact details', 'error'); }
                                    });
                                }

                                function showContactDetails(c) {
                                    const date = c.createdAt ? moment(c.createdAt).format('MMMM DD, YYYY h:mm A') : '-';
                                    const statusClass = c.isRead ? 'badge-success' : 'badge-warning';
                                    const statusText = c.isRead ? 'Replied' : 'Unread';

                                    $('#view-contact-content').html(`
            <div style="max-width:480px; margin:auto;">
                <div style="display:flex; align-items:center; gap:10px; margin-bottom:16px;">
                    <h4 style="margin:0;">${escapeHtml(c.fullName)}</h4>
                    <span class="event-badge ${statusClass}">${statusText}</span>
                </div>

                <div style="background:#f8f9fa; padding:18px 20px; border-radius:8px; margin-bottom:16px;">
                    <div style="margin-bottom:8px;">
                        <strong>Email:</strong>
                        <a href="mailto:${escapeHtml(c.email)}">${escapeHtml(c.email)}</a>
                    </div>
                    <div style="margin-bottom:8px;">
                        <strong>Phone:</strong> ${escapeHtml(c.mobileNumber)}
                    </div>
                    <div>
                        <strong>Received:</strong> ${date}
                    </div>
                </div>

              <div style="background:#fff; border:1px solid #eee; padding:18px 20px; border-radius:8px; margin-bottom:16px;">
    <strong>Subject:</strong>
    <div style="white-space:pre-line; margin-top:8px; line-height:1.6;">
        ${c.subject ? escapeHtml(c.subject) : "<span style='color:#aaa;'>No subject provided.</span>"}
    </div>
</div>

                ${!c.isRead ? `
                    <div style="display:flex; justify-content:flex-end;">
                        <button class="btn btn-primary" onclick="replyContact('${c._id}')">
                            <i class="icon-mail"></i> Mark as Replied
                        </button>
                    </div>
                ` : ''}
            </div>
        `);
                                }

                                // ── Mark as replied ─────────────────────────────────────────────────────────
                                function replyContact(id) {
                                    $.ajax({
                                        url: `${CONTACT_MARK_REPLIED_API}/${id}`,
                                        method: 'PUT',
                                        success: function () {
                                            closeModal('view-contact-modal');
                                            loadContacts();
                                            showNotification('Marked as replied.', 'success');
                                        },
                                        error: function () { showNotification('Failed to mark as replied', 'error'); }
                                    });
                                }

                                // ── Delete ──────────────────────────────────────────────────────────────────
                                function openDeleteContactModal(id) {
                                    contactDeleteId = id;
                                    $('#confirm-delete-modal').show();
                                }

                                function deleteContact(id) {
                                    $.ajax({
                                        url: `${CONTACT_DELETE_API}/${id}`,
                                        method: 'DELETE',
                                        success: function () {
                                            closeModal('confirm-delete-modal');
                                            loadContacts();
                                            showNotification('Contact deleted successfully', 'success');
                                            contactDeleteId = null;
                                        },
                                        error: function () { showNotification('Failed to delete contact', 'error'); }
                                    });
                                }

                                // ── Pagination ──────────────────────────────────────────────────────────────
                                function updateContactPagination(totalPages) {
                                    contactTotalPages = totalPages || 1;
                                    const $p = $('#contact-pagination').empty();

                                    $p.append(`<li class="${contactPage === 1 ? 'disabled' : ''}">
            <a href="#" onclick="changeContactPage(${contactPage - 1})">&lt;</a></li>`);

                                    for (let i = 1; i <= contactTotalPages; i++) {
                                        if (i === 1 || i === contactTotalPages || (i >= contactPage - 2 && i <= contactPage + 2)) {
                                            $p.append(`<li class="${i === contactPage ? 'active' : ''}">
                    <a href="#" onclick="changeContactPage(${i})">${i}</a></li>`);
                                        } else if (i === contactPage - 3 || i === contactPage + 3) {
                                            $p.append('<li><span>…</span></li>');
                                        }
                                    }

                                    $p.append(`<li class="${contactPage === contactTotalPages ? 'disabled' : ''}">
            <a href="#" onclick="changeContactPage(${contactPage + 1})">&gt;</a></li>`);
                                }

                                function changeContactPage(page) {
                                    if (page < 1 || page > contactTotalPages) return;
                                    contactPage = page;
                                    loadContacts();
                                }

                                // ── Helpers ─────────────────────────────────────────────────────────────────
                                function closeModal(id) { $('#' + id).hide(); }

                                function escapeHtml(text) {
                                    return String(text || '').replace(/[&<>"]/g, c =>
                                        ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c])
                                    );
                                }

                                function showNotification(msg, type = 'info') { alert(msg); }

                                window.closeModal = closeModal;
                                window.viewContact = viewContact;
                                window.replyContact = replyContact;
                                window.openDeleteContactModal = openDeleteContactModal;
                                window.changeContactPage = changeContactPage;
                            </script>
                            <style>
                                .contacts-container .event-card {
                                    border-left: 5px solid #e0e0e0;
                                    margin-bottom: 12px;
                                    background: #fcfcfc;
                                }

                                .contacts-container .event-badge.badge-warning {
                                    background: #fff3cd;
