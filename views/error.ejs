<!DOCTYPE html>
<html lang="zxx">

<head>
    <!-- Meta -->
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1">
    <meta name="description" content="">
    <meta name="keywords" content="">
    <meta name="author" content="babios">
    <!-- Page Title -->
    <title>BABIOS | Something Went Wrong</title>
    <!-- Favicon Icon -->
    <link rel="shortcut icon" type="image/x-icon" href="/images/babios/logo.jpeg">
    <!-- Google Fonts Css-->
    <link rel="preconnect" href="https://fonts.googleapis.com/">
    <link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Onest:wght@100..900&display=swap" rel="stylesheet">
    <!-- Bootstrap Css -->
    <link href="/css/bootstrap.min.css" rel="stylesheet" media="screen">
    <!-- SlickNav Css -->
    <link href="/css/slicknav.min.css" rel="stylesheet">
    <!-- Font Awesome Icon Css-->
    <link href="/css/all.min.css" rel="stylesheet" media="screen">
    <!-- Animated Css -->
    <link href="/css/animate.css" rel="stylesheet">
    <!-- Mouse Cursor Css File -->
    <link rel="stylesheet" href="/css/mousecursor.css">
    <!-- Main Custom Css -->
    <link href="/css/custom.css" rel="stylesheet" media="screen">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <style>
        .error-page-section {
            min-height: 80vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 100px 20px;
            background: linear-gradient(to bottom, #f5fbfb, #eaf6f6, #ffffff);
            position: relative;
            overflow: hidden;
        }

        .error-page-section::before {
            content: '';
            position: absolute;
            top: -100px;
            left: -100px;
            width: 400px;
            height: 400px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(0, 150, 136, 0.15) 0%, transparent 70%);
            pointer-events: none;
        }

        .error-page-section::after {
            content: '';
            position: absolute;
            bottom: -100px;
            right: -100px;
            width: 400px;
            height: 400px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(0, 150, 136, 0.1) 0%, transparent 70%);
            pointer-events: none;
        }

        .error-content-wrap {
            text-align: center;
            position: relative;
            z-index: 2;
            max-width: 650px;
            margin: 0 auto;
        }

        .error-code {
            font-size: 160px;
            font-weight: 900;
            line-height: 1;
            color: transparent;
            -webkit-text-stroke: 2px rgba(0, 150, 136, 0.5);
            letter-spacing: -5px;
            margin-bottom: 10px;
            font-family: 'Onest', sans-serif;
            position: relative;
        }

        .error-code span {
            color: #009688;
            -webkit-text-stroke: 0;
        }

        .error-icon-wrap {
            margin: 20px auto;
            width: 80px;
            height: 80px;
            border-radius: 50%;
            border: 2px solid rgba(0, 150, 136, 0.4);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .error-icon-wrap i {
            font-size: 32px;
            color: #009688;
        }

        .error-title {
            font-size: 30px;
            font-weight: 700;
            color: #1a3a3c;
            margin-bottom: 16px;
            font-family: 'Onest', sans-serif;
        }

        .error-message {
            font-size: 16px;
            color: #4a6a6c;
            margin-bottom: 40px;
            line-height: 1.7;
        }

        .error-message strong {
            color: #1a3a3c;
        }

        .error-btn-group {
            display: flex;
            gap: 16px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .error-divider {
            width: 60px;
            height: 3px;
            background: #009688;
            border-radius: 2px;
            margin: 20px auto 30px;
        }

        /* Mobile bottom nav active state */
        .babios-mobile-nav .babios-nav-item.active {
            color: #009688;
        }
    </style>
</head>

<body>

    <!-- Preloader Start -->
    <div class="preloader">
        <div class="loading-container">
            <div class="loading"></div>
            <div id="loading-icon"><img src="/images/babios/logo.jpeg" alt=""></div>
        </div>
    </div>
    <!-- Preloader End -->

    <!-- Header Start -->
    <header class="main-header active-sticky-header header-metal">
        <div class="header-sticky bg-section">
            <nav class="navbar navbar-expand-lg">
                <div class="container-fluid">
                    <!-- Logo Start -->
                    <a class="navbar-brand" href="/">
                        <img src="/images/babios/logo.png" alt="Logo">
                    </a>
                    <!-- Logo End -->

                    <!-- Main Menu Start -->
                    <div class="collapse navbar-collapse main-menu">
                        <div class="nav-menu-wrapper">
                            <ul class="navbar-nav mr-auto" id="menu">
                                <li class="nav-item">
                                    <a class="nav-link" href="/">Welcome Home</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="/about">Who We Are</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="/blog">Our Blog & Stories</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="/contact">Contact & Support</a>
                                </li>
                            </ul>
                        </div>
                        <div class="header-btn">
                            <a href="/contact" class="btn-default btn-highlighted">Get In Touch</a>
                        </div>
                    </div>
                    <!-- Main Menu End -->
                    <div class="navbar-toggle"></div>
                </div>
            </nav>
            <div class="responsive-menu"></div>
        </div>
    </header>
    <!-- Header End -->

    <!-- Error Section Start -->
    <div class="error-page-section ">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-xl-8 col-lg-10">
                    <div class="error-content-wrap wow fadeInUp">

                        <div class="error-code">
                            <span>
                                <%= status || 500 %>
                            </span>
                        </div>

                        <div class="error-divider"></div>

                        <div class="error-icon-wrap">
                            <i class="fa-solid fa-triangle-exclamation"></i>
                        </div>

                        <h2 class="error-title">
                            <%= status===404 ? "Page Not Found" : "Something Went Wrong" %>
                        </h2>

                        <p class="error-message">
                            <% if (status===404) { %>
                                Oops! The page you're looking for doesn't exist or has been moved.<br>
                                Let's get your little ones back to the good stuff.
                                <% } else { %>
                                    We're sorry, something went wrong on our end.<br>
                                    <% if (message) { %>
                                        <strong>
                                            <%= message %>
                                        </strong><br>
                                        <% } %>
                                            Please try again or head back to the homepage.
                                            <% } %>
                        </p>

                        <div class="error-btn-group">
                            <a href="/" class="btn-default btn-highlighted">
                                <i class="fa-solid fa-house" style="margin-right:8px;"></i> Back to Home
                            </a>
                            <a href="/contact" class="btn-default">
                                Contact Support
                            </a>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Error Section End -->

    <!-- Footer Section Start -->
    <footer class="main-footer-metal dark-section">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="footer-body-metal">
                        <div class="about-footer-metal">
                            <div class="footer-logo-metal">
                                <img src="/images/babios/logo.jpeg" alt="">
                            </div>
                        </div>
                        <div class="footer-contact-list-metal">
                            <div class="footer-contact-item-metal">
                                <h3>Phone Number</h3>
                                <p><img src="/images/icon-phone-white.svg" alt=""><a href="tel:123456789">+(123)
                                        456-789</a></p>
                            </div>
                            <div class="footer-contact-item-metal">
                                <h3>Email Address</h3>
                                <p><img src="/images/icon-email.svg" alt=""><a
                                        href="mailto:info@babios.com">info@babios.com</a></p>
                            </div>
                            <div class="footer-contact-item-metal">
                                <h3>Our Location</h3>
                                <p><img src="/images/icon-location-white.svg" alt="">271 Ash Dr. San Jose, South Dakota
                                    834</p>
                            </div>
                        </div>
                    </div>

                    <div class="footer-menu-box-metal">
                        <div class="footer-menu-metal">
                            <ul>
                                <li><a href="/">Welcome Home</a></li>
                                <li><a href="/about">Who We Are</a></li>
                                <li><a href="/blog">Our Blog & Stories</a></li>
                                <li><a href="/contact">Contact & Support</a></li>
                            </ul>
                        </div>
                        <div class="footer-privacy-policy-metal">
                            <ul class="social-icons">
                                <li>
                                    <a href="#">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                                            <path
                                                d="M18.244 2H21l-6.61 7.56L22 22h-6.828l-5.35-6.97L3.7 22H1l7.07-8.08L2 2h6.828l4.84 6.32L18.244 2zM16.97 20h1.88L7.05 4H5.05l11.92 16z" />
                                        </svg>
                                    </a>
                                </li>
                                <li>
                                    <a href="#">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                                            <path
                                                d="M22 12a10 10 0 1 0-11.63 9.87v-6.99H8.08V12h2.29V9.8c0-2.27 1.35-3.53 3.42-3.53.99 0 2.03.18 2.03.18v2.23h-1.14c-1.12 0-1.47.7-1.47 1.41V12h2.5l-.4 2.88h-2.1v6.99A10 10 0 0 0 22 12z" />
                                        </svg>
                                    </a>
                                </li>
                                <li>
                                    <a href="#">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                                            <path
                                                d="M7 2C4.24 2 2 4.24 2 7v10c0 2.76 2.24 5 5 5h10c2.76 0 5-2.24 5-5V7c0-2.76-2.24-5-5-5H7zm5 5.5A4.5 4.5 0 1 1 7.5 12 4.5 4.5 0 0 1 12 7.5zm0 7.4A2.9 2.9 0 1 0 9.1 12 2.9 2.9 0 0 0 12 14.9zM17.8 6.2a1.05 1.05 0 1 1-1.05-1.05 1.05 1.05 0 0 1 1.05 1.05z" />
                                        </svg>
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>

                    <div class="footer-copyright-text-metal">
                        <p>
                            Copyright © 2026 Babios. All Rights Reserved. |
                            Developed by <a class="text-white" href="https://trivlogic.com" target="_blank">Trivlogic
                                Private Limited</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </footer>
    <!-- Footer Section End -->

    <!-- Floating Buttons -->
    <div class="babios-float-wrap">
        <a href="https://wa.me/919XXXXXXXXX" class="babios-float-btn babios-whatsapp" target="_blank">
            <span class="babios-tooltip">Chat with us</span>
            <i class="fa-brands fa-whatsapp"></i>
        </a>
        <a href="tel:+919XXXXXXXXX" class="babios-float-btn babios-call">
            <span class="babios-tooltip">Call us</span>
            <i class="fa-solid fa-phone"></i>
        </a>
    </div>

    <!-- Mobile Nav -->
    <div class="babios-mobile-nav">
        <a href="/" class="babios-nav-item">
            <i class="fa-solid fa-house"></i>
            <span>Home</span>
        </a>
        <a href="/about" class="babios-nav-item">
            <i class="fa-solid fa-user"></i>
            <span>About</span>
        </a>
        <a href="/blog" class="babios-nav-item">
            <i class="fa-solid fa-blog"></i>
            <span>Blogs</span>
        </a>
        <a href="/contact" class="babios-nav-item">
            <i class="fa-solid fa-phone"></i>
            <span>Contact</span>
        </a>
    </div>

    <!-- Scripts -->
    <script src="/js/jquery-3.7.1.min.js"></script>
    <script src="/js/bootstrap.min.js"></script>
    <script src="/js/jquery.slicknav.js"></script>
    <script src="/js/gsap.min.js"></script>
    <script src="/js/magiccursor.js"></script>
    <script src="/js/wow.min.js"></script>
    <script src="/js/function.js"></script>
</body>

</html>