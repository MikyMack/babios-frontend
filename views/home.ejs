                                        <div class="section-title">

                                            <h1 class="wow fadeInUp" data-wow-delay="0.2s" data-cursor="-opaque">
                                                <%= banner.title %> <br>
                                                    <span class="hero-title-image-metal"><img
                                                            src="images/babios/banner-1.jpg" alt=""></span>
                                                    Made for Big Smiles
